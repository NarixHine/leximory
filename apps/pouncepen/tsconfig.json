    ".next/dev/types/**/*.ts"
, "../../packages/ui/src/paper/choice.tsx", "../../packages/ui/src/paper/atoms.ts", "../../packages/ui/src/accordion/index.tsx", "../../packages/service/src/ai/prompts/sections.ts"  ],
}